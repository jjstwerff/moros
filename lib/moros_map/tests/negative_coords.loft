use moros_map;

fn test_negative_q() {
  m = map_empty();
  map_set_height(m, -1, 1, 0, 5);
  h = map_get_hex(m, -1, 1, 0);
  assert(h.h_height == 5, "h_height {h.h_height} — should be 5");
}

fn test_positive_q() {
  m = map_empty();
  map_set_height(m, 1, 1, 0, 5);
  h = map_get_hex(m, 1, 1, 0);
  assert(h.h_height == 5, "positive works");
}

fn test_negative_r() {
  m = map_empty();
  map_set_height(m, 0, -3, 0, 7);
  h = map_get_hex(m, 0, -3, 0);
  assert(h.h_height == 7, "negative r");
}
