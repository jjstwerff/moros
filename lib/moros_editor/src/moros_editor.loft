// moros_editor — edit operations on top of moros_map.
// Phase 4 per ../moros/doc/claude/SCENE_EDITOR_PLAN.md.

use moros_map;

// ── Undo stack ─────────────────────────────────────────────────────

// One undo entry: snapshot of a hex BEFORE an edit.
// ue_batch_id groups edits together; 0 = standalone, >0 = batch id
// shared by all edits inside one `batch_begin` / `batch_end` pair.
pub struct UndoEntry {
  ue_q:        integer not null,
  ue_r:        integer not null,
  ue_cy:       integer not null,
  ue_batch_id: integer not null,
  ue_prev:     Hex,
}

// LIFO undo stack with parallel redo stack.
// us_batch_id  — the id being tagged onto pushes inside a batch (0 = not in batch).
// us_next_id   — counter for the next unique batch id to assign.
pub struct UndoStack {
  us_entries:  vector<UndoEntry>,
  us_redo:     vector<UndoEntry>,
  us_batch_id: integer not null,
  us_next_id:  integer not null,
}

pub fn undo_empty() -> UndoStack {
  UndoStack { us_entries: [], us_redo: [], us_batch_id: 0, us_next_id: 1 }
}

pub fn undo_depth(s: UndoStack) -> integer { len(s.us_entries) }
pub fn redo_depth(s: UndoStack) -> integer { len(s.us_redo) }

// ── Batch mode ────────────────────────────────────────────────────

// Group all subsequent edits until `batch_end` as one logical undo step.
// Nested begin/end pairs collapse to the outermost batch.
pub fn batch_begin(s: &UndoStack) {
  if s.us_batch_id == 0 {
    s.us_batch_id = s.us_next_id;
    s.us_next_id = s.us_next_id + 1;
  }
}

pub fn batch_end(s: &UndoStack) {
  s.us_batch_id = 0;
}

pub fn in_batch(s: UndoStack) -> boolean { s.us_batch_id != 0 }

// ── Push / pop primitives ─────────────────────────────────────────

// Capture the hex at (q, r, cy) before mutating it.  Clears the redo stack.
pub fn undo_push(s: &UndoStack, m: Map, q: integer, r: integer, cy: integer) {
  prev = map_get_hex(m, q, r, cy);
  s.us_entries += [UndoEntry {
    ue_q: q, ue_r: r, ue_cy: cy,
    ue_batch_id: s.us_batch_id,
    ue_prev: prev,
  }];
  // Any fresh edit invalidates the redo history.
  s.us_redo = [];
}

// Count how many trailing entries in `v` share the same batch id as
// the top entry.  Always >= 1 when v is non-empty.  Standalone edits
// (batch_id == 0) are never grouped.
fn count_logical_group(v: vector<UndoEntry>) -> integer {
  n = len(v);
  if n == 0 { return 0; }
  top_id = v[n - 1].ue_batch_id;
  if top_id == 0 { return 1; }
  count = 0;
  for i in rev(0..n) {
    if v[i].ue_batch_id != top_id { break; }
    count = count + 1;
  }
  count
}

// Rebuild `v` without the last `drop` entries.  Used in place of a
// `pop_back` primitive on vectors.
fn without_tail(v: vector<UndoEntry>, drop: integer) -> vector<UndoEntry> {
  rebuilt: vector<UndoEntry> = [];
  keep = len(v) - drop;
  for i in 0..keep {
    rebuilt += [v[i]];
  }
  rebuilt
}

// ── Undo / redo ──────────────────────────────────────────────────

// Undo one logical operation (single edit or entire batch).
// Returns true if anything was undone.  Each reverted entry is pushed
// onto the redo stack carrying the post-edit state so `redo()` can
// reapply it.
pub fn undo_pop(s: &UndoStack, m: &Map) -> boolean {
  n = len(s.us_entries);
  if n == 0 { return false; }
  count = count_logical_group(s.us_entries);
  for k in 0..count {
    idx = n - 1 - k;
    e = s.us_entries[idx];
    cur = map_get_hex(m, e.ue_q, e.ue_r, e.ue_cy);
    s.us_redo += [UndoEntry {
      ue_q: e.ue_q, ue_r: e.ue_r, ue_cy: e.ue_cy,
      ue_batch_id: e.ue_batch_id,
      ue_prev: cur,
    }];
    map_set_hex(m, e.ue_q, e.ue_r, e.ue_cy, e.ue_prev);
  }
  s.us_entries = without_tail(s.us_entries, count);
  true
}

// Redo the last undone operation (single edit or entire batch).
// Returns true if anything was reapplied.
pub fn redo(s: &UndoStack, m: &Map) -> boolean {
  n = len(s.us_redo);
  if n == 0 { return false; }
  count = count_logical_group(s.us_redo);
  for k in 0..count {
    idx = n - 1 - k;
    e = s.us_redo[idx];
    cur = map_get_hex(m, e.ue_q, e.ue_r, e.ue_cy);
    s.us_entries += [UndoEntry {
      ue_q: e.ue_q, ue_r: e.ue_r, ue_cy: e.ue_cy,
      ue_batch_id: e.ue_batch_id,
      ue_prev: cur,
    }];
    map_set_hex(m, e.ue_q, e.ue_r, e.ue_cy, e.ue_prev);
  }
  s.us_redo = without_tail(s.us_redo, count);
  true
}

// ── Recording editors ─────────────────────────────────────────────
// Each wraps the corresponding moros_map convenience editor and
// records a pre-edit snapshot so the mutation can be undone.

pub fn paint_material_with_undo(s: &UndoStack, m: &Map, q: integer, r: integer, cy: integer, mat: integer) {
  undo_push(s, m, q, r, cy);
  map_paint_material(m, q, r, cy, mat);
}

pub fn set_height_with_undo(s: &UndoStack, m: &Map, q: integer, r: integer, cy: integer, height: integer) {
  undo_push(s, m, q, r, cy);
  map_set_height(m, q, r, cy, height);
}

pub fn adjust_height_with_undo(s: &UndoStack, m: &Map, q: integer, r: integer, cy: integer, delta: integer) {
  cur = map_get_hex(m, q, r, cy);
  undo_push(s, m, q, r, cy);
  map_set_height(m, q, r, cy, cur.h_height + delta);
}

pub fn place_item_with_undo(s: &UndoStack, m: &Map, q: integer, r: integer, cy: integer, item: integer, rotation: integer) {
  undo_push(s, m, q, r, cy);
  map_place_item(m, q, r, cy, item, rotation);
}

pub fn remove_item_with_undo(s: &UndoStack, m: &Map, q: integer, r: integer, cy: integer) {
  undo_push(s, m, q, r, cy);
  map_place_item(m, q, r, cy, 0, 0);
}

pub fn set_wall_with_undo(s: &UndoStack, m: &Map, q: integer, r: integer, cy: integer, edge: integer, wall: integer) {
  undo_push(s, m, q, r, cy);
  map_set_wall(m, q, r, cy, edge, wall);
}

// Wall with direction resolution (0-5) + undo.  Directions 3-5 store
// the wall on a neighbour hex, so we snapshot THAT hex instead.
pub fn set_wall_dir_with_undo(s: &UndoStack, m: &Map, q: integer, r: integer, cy: integer, dir: integer, wall: integer) {
  if dir == 3 { undo_push(s, m, q, r + 1, cy); }
  if dir == 4 { undo_push(s, m, q - 1, r + 1, cy); }
  if dir == 5 { undo_push(s, m, q - 1, r, cy); }
  if dir < 3 { undo_push(s, m, q, r, cy); }
  map_set_wall_dir(m, q, r, cy, dir, wall);
}

// Slope path with batch undo — all hexes in the slope are one
// logical undo step.
pub fn slope_path_with_undo(s: &UndoStack, m: &Map, q1: integer, r1: integer, q2: integer, r2: integer, cy: integer, h_start: integer, h_end: integer) {
  // Note: lerp_int and hex_distance are imported from moros_map.
  batch_begin(s);
  dist = hex_distance(q1, r1, q2, r2);
  if dist == 0 {
    set_height_with_undo(s, m, q1, r1, cy, h_start);
    batch_end(s);
    return;
  }
  for i in 0..=dist {
    q = lerp_int(q1, q2, i, dist);
    r = lerp_int(r1, r2, i, dist);
    h = lerp_int(h_start, h_end, i, dist);
    set_height_with_undo(s, m, q, r, cy, h);
  }
  batch_end(s);
}

// ── EditKind enum (Phase 4.5) ─────────────────────────────────────
// Typed undo entries — polymorphic enum with struct variants.
// Used for spawn/waypoint undo where a hex snapshot isn't sufficient.

pub enum EditKind {
  HexEdit {
    ek_q:    integer not null,
    ek_r:    integer not null,
    ek_cy:   integer not null,
    ek_prev: Hex
  },
  SpawnAdd {
    ek_q:      integer not null,
    ek_r:      integer not null,
    ek_cy:     integer not null,
    ek_npc_id: integer not null
  },
  SpawnRemove {
    ek_sp: SpawnPoint
  }
}

// Describe an edit kind as text (for debug/logging).
pub fn edit_kind_label(e: EditKind) -> text {
  match e {
    HexEdit { ek_q, ek_r, ek_cy } => "hex({ek_q},{ek_r},{ek_cy})",
    SpawnAdd { ek_npc_id } => "spawn_add(npc={ek_npc_id})",
    SpawnRemove => "spawn_remove"
  }
}

// Apply an undo for an EditKind entry: reverse the recorded operation.
fn undo_hex_edit(m: &Map, q: integer, r: integer, cy: integer, prev: Hex) {
  map_set_hex(m, q, r, cy, prev);
}

fn undo_spawn_add(m: &Map, q: integer, r: integer, cy: integer, npc_id: integer) {
  spawn_remove(m, q, r, cy, npc_id);
}

fn undo_spawn_remove(m: &Map, sp: SpawnPoint) {
  spawn_add(m, sp);
}

pub fn edit_kind_undo(e: EditKind, m: &Map) {
  match e {
    HexEdit { ek_q, ek_r, ek_cy, ek_prev } => undo_hex_edit(m, ek_q, ek_r, ek_cy, ek_prev),
    SpawnAdd { ek_q, ek_r, ek_cy, ek_npc_id } => undo_spawn_add(m, ek_q, ek_r, ek_cy, ek_npc_id),
    SpawnRemove { ek_sp } => undo_spawn_remove(m, ek_sp)
  }
}

// ── Stencils (Phase 4.13–4.16) ────────────────────────────────────

// One hex inside a stencil template.  Offsets are relative to the
// stencil origin.  A value of 0 means "leave unchanged" for material,
// item, and walls in overlay mode.
pub struct StencilHex {
  sh_dq:            integer not null,
  sh_dr:            integer not null,
  sh_height:        integer not null,
  sh_material:      integer not null,
  sh_item:          integer not null,
  sh_item_rotation: integer not null,
  sh_wall_n:        integer not null,
  sh_wall_ne:       integer not null,
  sh_wall_se:       integer not null,
}

// A named stamp template.
pub struct StencilDef {
  sd_name:     text,
  sd_category: text,
  sd_origin_q: integer not null,
  sd_origin_r: integer not null,
  sd_hexes:    vector<StencilHex>,
}

// Merge modes for stencil_stamp.
// 0 = REPLACE   — overwrite every field.
// 1 = OVERLAY   — skip fields where the stencil value is 0.
// 2 = HEIGHTS   — only write height; ignore material/item/walls.
// 3 = STRUCTURE — only write material/item/walls; ignore height.

// Apply a stencil to the map at position (q, r, cy) with the given
// merge mode (0–3).  Each stencil hex's offsets are added to (q, r).
pub fn stencil_stamp(m: &Map, stencil: StencilDef, q: integer, r: integer, cy: integer, mode: integer) {
  for ss_sh in stencil.sd_hexes {
    tq = q + ss_sh.sh_dq - stencil.sd_origin_q;
    tr = r + ss_sh.sh_dr - stencil.sd_origin_r;
    cur = map_get_hex(m, tq, tr, cy);
    if mode == 0 {
      // REPLACE — overwrite everything.
      cur.h_height = ss_sh.sh_height;
      cur.h_material = ss_sh.sh_material;
      cur.h_item = ss_sh.sh_item;
      cur.h_item_rotation = ss_sh.sh_item_rotation;
      cur.h_wall_n = ss_sh.sh_wall_n;
      cur.h_wall_ne = ss_sh.sh_wall_ne;
      cur.h_wall_se = ss_sh.sh_wall_se;
    }
    if mode == 1 {
      // OVERLAY — skip zero values (leave map hex unchanged for those).
      if ss_sh.sh_height != 0 { cur.h_height = ss_sh.sh_height; }
      if ss_sh.sh_material != 0 { cur.h_material = ss_sh.sh_material; }
      if ss_sh.sh_item != 0 { cur.h_item = ss_sh.sh_item; }
      if ss_sh.sh_item_rotation != 0 { cur.h_item_rotation = ss_sh.sh_item_rotation; }
      if ss_sh.sh_wall_n != 0 { cur.h_wall_n = ss_sh.sh_wall_n; }
      if ss_sh.sh_wall_ne != 0 { cur.h_wall_ne = ss_sh.sh_wall_ne; }
      if ss_sh.sh_wall_se != 0 { cur.h_wall_se = ss_sh.sh_wall_se; }
    }
    if mode == 2 {
      // HEIGHTS only.
      cur.h_height = ss_sh.sh_height;
    }
    if mode == 3 {
      // STRUCTURE only — material, item, walls.
      cur.h_material = ss_sh.sh_material;
      cur.h_item = ss_sh.sh_item;
      cur.h_item_rotation = ss_sh.sh_item_rotation;
      cur.h_wall_n = ss_sh.sh_wall_n;
      cur.h_wall_ne = ss_sh.sh_wall_ne;
      cur.h_wall_se = ss_sh.sh_wall_se;
    }
    map_set_hex(m, tq, tr, cy, cur);
  }
}

// Stamp with undo — all hex writes are one batch.
pub fn stencil_stamp_with_undo(s: &UndoStack, m: &Map, stencil: StencilDef, q: integer, r: integer, cy: integer, mode: integer) {
  batch_begin(s);
  for su_sh in stencil.sd_hexes {
    tq = q + su_sh.sh_dq - stencil.sd_origin_q;
    tr = r + su_sh.sh_dr - stencil.sd_origin_r;
    undo_push(s, m, tq, tr, cy);
  }
  stencil_stamp(m, stencil, q, r, cy, mode);
  batch_end(s);
}

// ── Built-in stencils ─────────────────────────────────────────────

// 7-hex "small house" stencil: centre + 6 surrounding hexes.
// Centre is floor (material 2), ring is walls (material 1, wall_n/ne/se = 1).
pub fn stencil_house_small() -> StencilDef {
  hexes: vector<StencilHex> = [];
  // Centre hex — floor only.
  hexes += [StencilHex {
    sh_dq: 0, sh_dr: 0,
    sh_height: 0, sh_material: 2, sh_item: 0, sh_item_rotation: 0,
    sh_wall_n: 0, sh_wall_ne: 0, sh_wall_se: 0,
  }];
  // Ring of 6 — axial neighbours with walls.
  neighbours: vector<integer> = [1, 0, 0, 1, -1, 1, -1, 0, 0, -1, 1, -1];
  for i in 0..6 {
    dq = neighbours[i * 2];
    dr = neighbours[i * 2 + 1];
    hexes += [StencilHex {
      sh_dq: dq, sh_dr: dr,
      sh_height: 0, sh_material: 1, sh_item: 0, sh_item_rotation: 0,
      sh_wall_n: 1, sh_wall_ne: 1, sh_wall_se: 1,
    }];
  }
  StencilDef {
    sd_name: "house_small",
    sd_category: "building",
    sd_origin_q: 0,
    sd_origin_r: 0,
    sd_hexes: hexes,
  }
}

// 1-hex flat terrain stencil — useful for testing.
pub fn stencil_flat() -> StencilDef {
  StencilDef {
    sd_name: "flat",
    sd_category: "terrain",
    sd_origin_q: 0,
    sd_origin_r: 0,
    sd_hexes: [StencilHex {
      sh_dq: 0, sh_dr: 0,
      sh_height: 5, sh_material: 3, sh_item: 0, sh_item_rotation: 0,
      sh_wall_n: 0, sh_wall_ne: 0, sh_wall_se: 0,
    }],
  }
}

// 3-hex spiral stair: centre ramp + two side walls stepping up.
pub fn stencil_spiral_stair() -> StencilDef {
  StencilDef {
    sd_name: "spiral_stair",
    sd_category: "building",
    sd_origin_q: 0,
    sd_origin_r: 0,
    sd_hexes: [
      StencilHex { sh_dq: 0, sh_dr: 0, sh_height: 0, sh_material: 4, sh_item: 0, sh_item_rotation: 0, sh_wall_n: 0, sh_wall_ne: 0, sh_wall_se: 0 },
      StencilHex { sh_dq: 1, sh_dr: 0, sh_height: 3, sh_material: 4, sh_item: 0, sh_item_rotation: 0, sh_wall_n: 2, sh_wall_ne: 0, sh_wall_se: 0 },
      StencilHex { sh_dq: 0, sh_dr: 1, sh_height: 6, sh_material: 4, sh_item: 0, sh_item_rotation: 0, sh_wall_n: 0, sh_wall_ne: 2, sh_wall_se: 0 },
    ],
  }
}

// ── Stencil capture (Phase 4.17) ──────────────────────────────────

// Capture a rectangular region of the map as a StencilDef.
// All hexes in the q∈[q1,q2], r∈[r1,r2] range are read.
// The origin is set to (q1, r1).
pub fn stencil_save(m: Map, name: text, category: text, q1: integer, r1: integer, q2: integer, r2: integer, cy: integer) -> StencilDef {
  hexes: vector<StencilHex> = [];
  for q in q1..=q2 {
    for r in r1..=r2 {
      h = map_get_hex(m, q, r, cy);
      hexes += [StencilHex {
        sh_dq: q, sh_dr: r,
        sh_height: h.h_height,
        sh_material: h.h_material,
        sh_item: h.h_item,
        sh_item_rotation: h.h_item_rotation,
        sh_wall_n: h.h_wall_n,
        sh_wall_ne: h.h_wall_ne,
        sh_wall_se: h.h_wall_se,
      }];
    }
  }
  StencilDef {
    sd_name: name,
    sd_category: category,
    sd_origin_q: q1,
    sd_origin_r: r1,
    sd_hexes: hexes,
  }
}

// ── Stencil JSON (Phase 4.17) ─────────────────────────────────────

// Serialize a stencil to JSON for storage/transfer.
pub fn stencil_to_json(st: StencilDef) -> text { "{st:j}" }

// Deserialize a stencil from JSON.
pub fn stencil_from_json(json: text) -> StencilDef { StencilDef.parse(json) }

// ── Editor lifecycle (Phase 4.19) ─────────────────────────────────

// Save the complete editor state as JSON.  Currently wraps
// map_to_json — undo history is runtime-only and not persisted.
pub fn editor_save(m: Map) -> text { map_to_json(m) }

// Initialise the editor from a previously-saved JSON string.
// Returns an empty map on parse failure.
pub fn editor_init(json: text) -> Map { map_from_json(json) }
