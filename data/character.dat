  actions: [
    { power: "Inspire", name: "strategy", needs: "Char >= 3",
      description: "All players may put another card on the pile. Every Char > 3 to remove cards." },
    { power: "Inspire", name: "boost", needs: "Char >= 4",
      description: "Players can play two cards in their next round instead of the normal one." },
    { power: "Parry", name: "repost", needs: "Reaction, Dex > Might",
      description: "Allows the player to attack with the same card, it will always count as might 0." },
    { power: "Trick", name: "disarm", needs: "Hand > Dex + Might",
      description: "The weapon of the other party goes flying. It can be replaced in a turn." },
    { power: "Spot", name: "weak point", needs: "Perc > Dex + Might",
      description: "Allow a player a second card for their next attack on this enemy." },
    { power: "Move", name: "dodge", needs: "Reaction, Speed > Dex",
      description: "Move out of the way of an attack with taking one step back or beside for ranged." }
  ],
