target
.idea
.claude/
data/pages.zip
node_modules
package-lock.json
coverage
.nyc_output

# Auto-archived prior versions of generated card art (kept locally
# by tools/generate_card_art.py archive_existing()).
html/icons/**/*_v[0-9][0-9].png
images/*_v[0-9][0-9].png

# Python bytecode caches from tooling.
tools/__pycache__/
__pycache__/


# loft build artifacts inside the lib/ packages: `native-auto/` holds the
# auto-compiled native cdylib (14 MB and machine-specific), `.loft/` the
# resolver cache.  The committed `.loft/api/*.api` stubs are the exception —
# they are the readable public surface of a locked dependency.
lib/**/native-auto/
lib/**/.loft/
!lib/**/.loft/api/

# The moros_render CLI examples write their .glb cwd-relative by design.
*.glb
